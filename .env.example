# ─────────────────────────────────────────
# Embark — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# Sentry (optional — error monitoring)
# Create a project at https://sentry.io and paste the DSN here
# Leave blank to disable Sentry in development
VITE_SENTRY_DSN=

# App metadata (optional — used in PWA manifest and meta tags)
VITE_APP_URL=http://localhost:5173

# API backend URL (Hono server)
VITE_API_URL=http://localhost:3001
